<RCC>
  <qresource prefix="/">
    <file alias="icon.png">resources/icons/icon.png</file>
    <file alias="style.qss">resources/style.qss</file>
    <file alias="arrow_down.png">resources/images/arrow_down.png</file>
    <file alias="arrow_down_accent.png">resources/images/arrow_down_accent.png</file>
    <file alias="arrow_up.png">resources/images/arrow_up.png</file>
    <file alias="check.png">resources/images/check.png</file>
  </qresource>
</RCC>
